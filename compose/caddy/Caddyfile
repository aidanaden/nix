# Caddy configuration for aidanaden.com services
# With Authelia SSO and Sablier integration

{
    # Use Cloudflare DNS challenge for wildcard cert
    acme_dns cloudflare {env.CF_API_TOKEN}
    
    # Enable Sablier plugin
    order sablier before reverse_proxy
}

# Authelia portal
auth.aidanaden.com {
    tls {
        dns cloudflare {env.CF_API_TOKEN}
    }
    reverse_proxy authelia:9091
}

# Wildcard cert for all subdomains
*.aidanaden.com {
    tls {
        dns cloudflare {env.CF_API_TOKEN}
    }
    
    # ===== SLEEPABLE SERVICES (Sablier + Authelia) =====
    
    @pdf host pdf.aidanaden.com
    handle @pdf {
        forward_auth authelia:9091 {
            uri /api/authz/forward-auth
            copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
        }
        sablier {
            names stirling-pdf-stirling-pdf-1
            session_duration 15m
            dynamic {
                display_name "Stirling PDF"
                theme hacker-terminal
            }
        }
        reverse_proxy 100.92.143.10:9080
    }
    
    @cyberchef host cyberchef.aidanaden.com
    handle @cyberchef {
