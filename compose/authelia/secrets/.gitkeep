# This directory holds Authelia secrets
# DO NOT commit actual secret files!
# 
# Required files (create on NAS):
#   jwt_secret.txt         - Random 64+ character string
#   session_secret.txt     - Random 64+ character string  
#   storage_encryption_key.txt - Random 64+ character string
#
# Generate with:
#   openssl rand -hex 32 > jwt_secret.txt
#   openssl rand -hex 32 > session_secret.txt
#   openssl rand -hex 32 > storage_encryption_key.txt
